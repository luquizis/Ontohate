        <rdfs:label xml:lang="pt">Deepfake odiento</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Demonizacao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Demonizacao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Construcao da vitima como ameaca moral ou social.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estrategia simbolica.</rdfs:comment>
        <rdfs:label xml:lang="pt">Demonizacao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Depressao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Depressao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Dano_psicologico"/>
        <rdfs:comment xml:lang="pt">Estado emocional persistente de tristeza ou desanimo.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse especifica.</rdfs:comment>
        <rdfs:label xml:lang="pt">Depressao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Desejo -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Desejo">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Modo_mental"/>
        <rdfs:comment xml:lang="pt">Disposicao volitiva.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estado mental voltado a obtencao de determinado resultado.</rdfs:comment>
        <rdfs:label xml:lang="pt">Desejo</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Desinformacao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Desinformacao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Estrategia manipulativa.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Uso intencional de informacao falsa para prejudicar grupo.</rdfs:comment>
        <rdfs:label xml:lang="pt">Desinformacao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Destinatario_vitima -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Destinatario_vitima">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Nucleo"/>
        <rdfs:comment xml:lang="pt">Agente social alvo do discurso de odio online.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Papeis/grupos alvo do discurso.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Polo passivo do evento.</rdfs:comment>
        <rdfs:label xml:lang="pt">Destinatario vitima</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Desumanizacao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Desumanizacao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Dano_social"/>
        <rdfs:comment xml:lang="pt">Processo de negacao da dignidade humana da vitima.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse conceitual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Desumanizacao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Difamacao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Difamacao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Conecta com dano moral.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Divulgacao de informacao ofensiva a reputacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">Difamacao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Dificuldade_de_respiracao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Dificuldade_de_respiracao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Dano_fisico"/>
        <rdfs:comment xml:lang="pt">Alteracao fisiologica relacionada a estados de estresse intenso.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse de Dano_fisico.</rdfs:comment>
        <rdfs:label xml:lang="pt">Dificuldade de respiracao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Direitos_negados -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Direitos_negados">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Argumentacao para retirada de direitos.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estrategia normativa.</rdfs:comment>
        <rdfs:label xml:lang="pt">Direitos negados</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_LGBTQIfobico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_LGBTQIfobico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_afetiva"/>
        <rdfs:comment xml:lang="pt">Classe especifica sob Natureza_principal (via Natureza_afetiva).</rdfs:comment>
        <rdfs:comment xml:lang="pt">Discurso de odio direcionado a pessoas LGBTQIA+.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso LGBTQIfobico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_antissemita -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_antissemita">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_dispositiva"/>
        <rdfs:comment xml:lang="pt">Classe especifica sob Natureza_principal; pode participar de interseccionalidade.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Discurso de odio direcionado contra pessoas judias.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso antissemita</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_aporofobico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_aporofobico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_por_conduta"/>
        <rdfs:comment xml:lang="pt">Classe especifica sob Natureza_principal.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Discurso de odio direcionado a pessoas em situacao de pobreza ou vulnerabilidade economica.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso aporofobico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_capacitista -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_capacitista">
