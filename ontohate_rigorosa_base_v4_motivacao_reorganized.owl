<?xml version="1.0"?>
<rdf:RDF xmlns="http://ontohate.org/ontohate#"
     xml:base="http://ontohate.org/ontohate"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://ontohate.org/ontohate">
        <rdfs:label xml:lang="pt">OntoHate (rigorosa, simplificada, baseada no XLSX)</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://ontohate.org/ontohate#expressa_conteudo -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#expressa_conteudo">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Conteudo"/>
        <rdfs:comment xml:lang="pt">Relaciona o evento de discurso ao conteudo informacional expresso.</rdfs:comment>
        <rdfs:label xml:lang="pt">expressa conteudo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#ocorre_em -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#ocorre_em">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Contexto"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso ao contexto em que ocorre.</rdfs:comment>
        <rdfs:label xml:lang="pt">ocorre em</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_consequencia -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_consequencia">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Consequencia"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso a consequencias/impactos.</rdfs:comment>
        <rdfs:label xml:lang="pt">tem consequencia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_destinatario -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_destinatario">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Destinatario_vitima"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso ao(s) destinatario(s)/vitima(s).</rdfs:comment>
        <rdfs:label xml:lang="pt">tem destinatario vitima</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_manifestacao -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_manifestacao">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Manifestacao"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso a formas de manifestacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">tem manifestacao</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_moderacao -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_moderacao">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Moderacao"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso a acoes/processos de moderacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">tem moderacao</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_motivacao -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_motivacao">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Motivacao"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso a motivacoes.</rdfs:comment>
        <rdfs:label xml:lang="pt">tem motivacao</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_natureza -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_natureza">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Natureza"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso a qualidades/caracteristicas.</rdfs:comment>
        <rdfs:label xml:lang="pt">tem natureza</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#tem_nucleo -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#tem_nucleo">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Nucleo"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso ao seu nucleo conceitual.</rdfs:comment>
        <rdfs:label xml:lang="pt">tem nucleo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ontohate.org/ontohate#usa_recurso -->

    <owl:ObjectProperty rdf:about="http://ontohate.org/ontohate#usa_recurso">
        <rdfs:domain rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:range rdf:resource="http://ontohate.org/ontohate#Recursos"/>
        <rdfs:comment xml:lang="pt">Relaciona um discurso a recursos/estrategias utilizadas.</rdfs:comment>
        <rdfs:label xml:lang="pt">usa recurso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://ontohate.org/ontohate#Adversario_politico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Adversario_politico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Pessoa_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Pessoa identificada por posicionamento politico divergente.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse individual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Adversario politico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_denunciante -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_denunciante">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Nucleo"/>
        <rdfs:comment xml:lang="pt">Agente que reporta discurso de odio.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Ampliacao v2.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente denunciante</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_hibrido -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_hibrido">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Agente_odiador"/>
        <rdfs:comment xml:lang="pt">Agente que combina acao humana e suporte algoritmico.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Ampliacao v2.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente hibrido</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_influenciador -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_influenciador">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Agente_odiador"/>
        <rdfs:comment xml:lang="pt">Agente com alto alcance digital.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Ampliacao v2.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente influenciador</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_moderador -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_moderador">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Nucleo"/>
        <rdfs:comment xml:lang="pt">Agente responsavel por avaliar ou remover conteudo.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Participante regulador.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente moderador</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_moderador_automatico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_moderador_automatico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Agente_moderador"/>
        <rdfs:comment xml:lang="pt">Ampliacao v2.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Sistema automatizado de moderacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente moderador automatico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_odiador -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_odiador">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Nucleo"/>
        <rdfs:comment xml:lang="pt">Agente social que manifesta o discurso de odio online.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Participante ativo do evento.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente odiador</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_sintetico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_sintetico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Agente_odiador"/>
        <rdfs:comment xml:lang="pt">Agente nao humano que produz discurso de odio por meio de IA.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Ampliacao v2.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente sintetico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agente_testemunha -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agente_testemunha">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Nucleo"/>
        <rdfs:comment xml:lang="pt">Agente que presencia discurso de odio.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Ampliacao v2.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agente testemunha</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Agnostico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Agnostico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Pessoa_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Pessoa que afirma nao ser possivel conhecer a existencia de divindade.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse individual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Agnostico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Alcance -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Alcance">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Manifestacao"/>
        <rdfs:comment xml:lang="pt">Dimensao de impacto mensuravel.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Extensao quantitativa da exposicao de um conteudo odiento.</rdfs:comment>
        <rdfs:label xml:lang="pt">Alcance</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Ameaca -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Ameaca">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Declaracao de intencao de causar dano.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Pode configurar ilicito.</rdfs:comment>
        <rdfs:label xml:lang="pt">Ameaca</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Amplificacao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Amplificacao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Sistema_algoritmico"/>
        <rdfs:comment xml:lang="pt">Processo pelo qual a plataforma aumenta visibilidade de determinado conteudo.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Relaciona-se a dinamica de viralizacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">Amplificacao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Animalizacao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Animalizacao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Comparacao da vitima a animal.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estrategia de desumanizacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">Animalizacao</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Antonimia_odienta -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Antonimia_odienta">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Estrategia linguistica indireta.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Uso de oposicao semantica para inferiorizacao indireta.</rdfs:comment>
        <rdfs:label xml:lang="pt">Antonimia odienta</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Aprovacao_social -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Aprovacao_social">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Modo_mental"/>
        <rdfs:comment xml:lang="pt">Disposicao social.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Modo mental relacionado a busca por reconhecimento ou validacao social.</rdfs:comment>
        <rdfs:label xml:lang="pt">Aprovacao social</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Argumento_de_inferioridade_da_vitima -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Argumento_de_inferioridade_da_vitima">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Desqualificacao moral ou social da vitima.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estrategia central do discurso.</rdfs:comment>
        <rdfs:label xml:lang="pt">Argumento de inferioridade da vitima</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Argumento_de_normalidade_do_tratamento -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Argumento_de_normalidade_do_tratamento">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Estrategia de banalizacao.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Naturalizacao do tratamento discriminatorio.</rdfs:comment>
        <rdfs:label xml:lang="pt">Argumento de normalidade do tratamento</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Argumento_de_superioridade_do_odiador -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Argumento_de_superioridade_do_odiador">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Afirmacao de hierarquia moral ou social.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estrategia de legitimacao.</rdfs:comment>
        <rdfs:label xml:lang="pt">Argumento de superioridade do odiador</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Arrogancia_moral -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Arrogancia_moral">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Modo_mental"/>
        <rdfs:comment xml:lang="pt">Disposicao avaliativa.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Disposicao baseada na percepcao de superioridade moral.</rdfs:comment>
        <rdfs:label xml:lang="pt">Arrogancia moral</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Assexual -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Assexual">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Pessoa_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Pessoa com ausencia ou baixa atracao sexual.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse individual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Assexual</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Ateu -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Ateu">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Pessoa_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Pessoa que nao professa crenca religiosa.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse individual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Ateu</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Audiencia -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Audiencia">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Plataforma_digital"/>
        <rdfs:comment xml:lang="pt">Categoria estrutural de recepcao.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Conjunto de usuarios potencial ou efetivamente expostos ao conteudo.</rdfs:comment>
        <rdfs:label xml:lang="pt">Audiencia</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Bissexual -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Bissexual">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Pessoa_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Pessoa com atracao por mais de um genero.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse individual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Bissexual</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Bot_social -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Bot_social">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Recursos_Tecnicos"/>
        <rdfs:comment xml:lang="pt">Conta automatizada utilizada para produzir ou amplificar discurso odiento.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Estrategia automatizada.</rdfs:comment>
        <rdfs:label xml:lang="pt">Bot social</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Bystander -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Bystander">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Audiencia"/>
        <rdfs:comment xml:lang="pt">Importante para dinamica social do fenomeno.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Usuario que presencia o discurso de odio sem ser autor nem vitima direta.</rdfs:comment>
        <rdfs:label xml:lang="pt">Bystander</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Calunia -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Calunia">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
        <rdfs:comment xml:lang="pt">Atribuicao falsa de fato desonroso.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Pode configurar ilicito.</rdfs:comment>
        <rdfs:label xml:lang="pt">Calunia</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Candomblecista -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Candomblecista">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Pessoa_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Pessoa praticante do candomble.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse individual.</rdfs:comment>
        <rdfs:label xml:lang="pt">Candomblecista</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Coisa -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Coisa">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="pt">Raiz do dominio (continuante/entidade geral).</rdfs:comment>
        <rdfs:label xml:lang="pt">Coisa</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Coletivo_politico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Coletivo_politico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Grupo_de_pessoas_com_caracteristica_protegida"/>
        <rdfs:comment xml:lang="pt">Grupo organizado em torno de identidade politica.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Subclasse coletiva.</rdfs:comment>
        <rdfs:label xml:lang="pt">Coletivo politico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Comentario_odiento -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Comentario_odiento">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Recursos_de_Forma"/>
        <rdfs:comment xml:lang="pt">Forma interacional.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Intervencao textual inserida em interacao digital.</rdfs:comment>
        <rdfs:label xml:lang="pt">Comentario odiento</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Consequencia -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Consequencia">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Discurso_de_odio"/>
        <rdfs:comment xml:lang="pt">Efeitos/danos/impactos associados.</rdfs:comment>
        <rdfs:label xml:lang="pt">Consequencia</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Conspiracao -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Conspiracao">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Estrategias_Discursivas"/>
