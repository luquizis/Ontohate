    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Natureza_afetiva -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Natureza_afetiva">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_principal"/>
        <rdfs:comment xml:lang="pt">Natureza baseada em afetividade, orientacao sexual e identidade de genero.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Reinterpretacao V2 da categoria V1 “afetiva”.</rdfs:comment>
        <rdfs:label xml:lang="pt">Natureza afetiva</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Natureza_afiliativa -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Natureza_afiliativa">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_principal"/>
        <rdfs:comment xml:lang="pt">Natureza baseada em afiliacoes coletivas, etnia, cultura, nacionalidade ou comunidade.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Reinterpretacao V2 da categoria V1 “afiliativa”.</rdfs:comment>
        <rdfs:label xml:lang="pt">Natureza afiliativa</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Natureza_dispositiva -->

