        <rdfs:comment xml:lang="pt">Dano que afeta a integridade corporal da vitima.</rdfs:comment>
        <rdfs:label xml:lang="pt">Dano fisico</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Dano_provocado -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Dano_provocado">
