        <rdfs:comment xml:lang="pt">Consequencia resultante da manifestacao do discurso de odio online.</rdfs:comment>
        <rdfs:label xml:lang="pt">Dano provocado</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Dano_psicologico -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Dano_psicologico">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Dano_provocado"/>
        <rdfs:comment xml:lang="pt">Dano relacionado ao sofrimento emocional da vitima.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Dimensao central na tese.</rdfs:comment>
        <rdfs:label xml:lang="pt">Dano psicologico</rdfs:label>
    </owl:Class>
    


