        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_principal"/>
        <rdfs:comment xml:lang="pt">Natureza baseada em disposicoes, crencas e conviccoes ideologicas.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Reinterpretacao V2 da categoria V1 “dispositiva”.</rdfs:comment>
        <rdfs:label xml:lang="pt">Natureza dispositiva</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Natureza_interseccional -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Natureza_interseccional">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza"/>
        <rdfs:comment xml:lang="pt">Dimensao que indica combinacao de multiplas naturezas no mesmo ataque.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Mudanca V2: nao substitui a natureza principal; e dimensao combinatoria.</rdfs:comment>
        <rdfs:label xml:lang="pt">Natureza interseccional</rdfs:label>
    </owl:Class>
    


