        <rdfs:comment xml:lang="pt">Classe especifica sob Natureza_principal.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Discurso de odio direcionado contra pessoas com deficiencia.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso capacitista</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_de_odio -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_de_odio">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Evento_de_discurso_de_odio"/>
        <rdfs:comment xml:lang="pt">Classe central da ontologia.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Evento comunicacional de expressao/circulacao de odio.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Fenomeno comunicativo manifestado em Plataformas Digitais.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso de odio</rdfs:label>
        <rdfs:label xml:lang="pt">Discurso de odio online</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_de_odio_por_aparencia -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_de_odio_por_aparencia">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_por_atributos"/>
        <rdfs:comment xml:lang="pt">Discurso de odio baseado na aparencia corporal.</rdfs:comment>
        <rdfs:comment xml:lang="pt">No arranjo V2, fica sob Natureza_por_atributos.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso de odio por aparencia</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Discurso_etarista -->

    <owl:Class rdf:about="http://ontohate.org/ontohate#Discurso_etarista">
        <rdfs:subClassOf rdf:resource="http://ontohate.org/ontohate#Natureza_por_atributos"/>
        <rdfs:comment xml:lang="pt">Discurso de odio direcionado contra pessoas com base na idade.</rdfs:comment>
        <rdfs:comment xml:lang="pt">No arranjo V2, fica sob Natureza_por_atributos.</rdfs:comment>
        <rdfs:label xml:lang="pt">Discurso etarista</rdfs:label>
    </owl:Class>
    


