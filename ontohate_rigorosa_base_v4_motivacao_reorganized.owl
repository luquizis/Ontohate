        <rdfs:comment xml:lang="pt">Reinterpretacao V2 da categoria V1 “por conduta”.</rdfs:comment>
        <rdfs:label xml:lang="pt">Natureza por conduta</rdfs:label>
    </owl:Class>
    


    <!-- http://ontohate.org/ontohate#Natureza_principal -->

