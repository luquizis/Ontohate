        <IRI>#Contexto_algoritmico</IRI>
        <Literal xml:lang="pt">Contexto mediado por sistemas algorítmicos de recomendação e ranqueamento. Influencia visibilidade, amplificação e priorização de conteúdo. Ampliação ontológica contemporânea.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
