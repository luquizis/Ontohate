        <IRI>#Universo_de_evento</IRI>
        <Literal xml:lang="pt">Universo de evento</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Universo_de_evento</IRI>
        <Literal xml:lang="pt">Classe fundamentada na UFO-C que representa universais relacionados a eventos. Serve como base ontológica para modelar ocorrências no domínio do discurso de ódio online. Classe de fundamentação.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Universo_de_evento</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Classe fundamentada na UFO-C que representa universais relacionados a eventos. Serve como base ontológica para modelar ocorrências no domínio do discurso de ódio online. Classe de fundamentação.</Literal>
