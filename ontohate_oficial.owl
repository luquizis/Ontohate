        <Literal xml:lang="pt">Classe de fundamentacao.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Universo_de_evento</IRI>
        <Literal xml:lang="pt">Classe fundamentada na UFO-C que representa universais relacionados a eventos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Universo_de_evento</IRI>
