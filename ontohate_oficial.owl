        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Demonizacao</IRI>
        <Literal xml:lang="pt">Demonizacao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Demonizacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que usa de palavras de maldição, originárias de textos sagrados, para &quot;amaldiçoar&quot; o destinatário-vítima</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Demonizacao</IRI>
        <Literal xml:lang="pt">Justifica perseguição. Estratégia simbólica. Construção da vítima como ameaça moral ou social.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Demonizacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que usa de palavras de maldição, originárias de textos sagrados, para &quot;amaldiçoar&quot; o destinatário-vítima

[Complemento da planilha] Justifica perseguição. Estratégia simbólica. Construção da vítima como ameaça moral ou social.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Depressao</IRI>
        <Literal xml:lang="pt">Estado emocional persistente de tristeza ou desanimo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Depressao</IRI>
        <Literal xml:lang="pt">Subclasse especifica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Depressao</IRI>
        <Literal xml:lang="pt">Depressao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Depressao</IRI>
        <Literal xml:lang="pt">Pode ser agravado por exposição contínua ao discurso de ódio. Subclasse específica. Estado emocional persistente de tristeza ou desânimo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Depressao</IRI>
        <Literal xml:lang="pt">É um dano psicológico que desperta um transtorno afetivo manifestado por humor disfórico ou perda de interesse ou prazer nas atividades habituais
A perturbação do humor é proeminente e relativamente persistente

[Complemento da planilha] Pode ser agravado por exposição contínua ao discurso de ódio. Subclasse específica. Estado emocional persistente de tristeza ou desânimo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Desejo</IRI>
        <Literal xml:lang="pt">Disposicao volitiva.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Desejo</IRI>
        <Literal xml:lang="pt">Estado mental voltado a obtencao de determinado resultado.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Desejo</IRI>
        <Literal xml:lang="pt">Desejo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Desejo</IRI>
        <Literal xml:lang="pt">Estado mental voltado à obtenção de determinado resultado. No contexto do discurso de ódio online, pode envolver a intenção de causar danos simbólicos, sociais ou psicológicos. Disposição volitiva.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Desejo</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Estado mental voltado à obtenção de determinado resultado. No contexto do discurso de ódio online, pode envolver a intenção de causar danos simbólicos, sociais ou psicológicos. Disposição volitiva.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Desinformacao</IRI>
        <Literal xml:lang="pt">Estrategia manipulativa.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Desinformacao</IRI>
        <Literal xml:lang="pt">Uso intencional de informacao falsa para prejudicar grupo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Desinformacao</IRI>
        <Literal xml:lang="pt">Desinformacao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Desinformacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que usa de informação com impressão desequilibrada, super simplificada ou enganosa da realidade, com fins de prejudicar o destinatário-vítima e/ou manipular sua opinião</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Desinformacao</IRI>
        <Literal xml:lang="pt">Pode reforçar estereótipos e medo moral. Estratégia manipulativa. Uso intencional de informação falsa para prejudicar grupo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Desinformacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que usa de informação com impressão desequilibrada, super simplificada ou enganosa da realidade, com fins de prejudicar o destinatário-vítima e/ou manipular sua opinião

[Complemento da planilha] Pode reforçar estereótipos e medo moral. Estratégia manipulativa. Uso intencional de informação falsa para prejudicar grupo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Destinatario_vitima</IRI>
        <Literal xml:lang="pt">Agente social alvo do discurso de odio online.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Destinatario_vitima</IRI>
        <Literal xml:lang="pt">Papeis/grupos alvo do discurso.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Destinatario_vitima</IRI>
        <Literal xml:lang="pt">Polo passivo do evento.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Destinatario_vitima</IRI>
        <Literal xml:lang="pt">Destinatario vitima</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Desumanizacao</IRI>
        <Literal xml:lang="pt">Processo de negacao da dignidade humana da vitima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Desumanizacao</IRI>
        <Literal xml:lang="pt">Subclasse conceitual.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Desumanizacao</IRI>
        <Literal xml:lang="pt">Desumanizacao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Desumanizacao</IRI>
        <Literal xml:lang="pt">Reforça inferiorização simbólica e exclusão social. Subclasse conceitual. Processo de negação da dignidade humana da vítima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Desumanizacao</IRI>
        <Literal xml:lang="pt">É um dano social que resulta no tratamento desigual do destinatário-vítima
Interfere no reconhecimento de sua dignidade de pessoa, o que inclui não reconhecê-lo como ser humano

[Complemento da planilha] Reforça inferiorização simbólica e exclusão social. Subclasse conceitual. Processo de negação da dignidade humana da vítima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Difamacao</IRI>
        <Literal xml:lang="pt">Conecta com dano moral.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Difamacao</IRI>
        <Literal xml:lang="pt">Divulgacao de informacao ofensiva a reputacao.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Difamacao</IRI>
        <Literal xml:lang="pt">Difamacao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Difamacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que diminue a reputação ou a boa reputação do destinatário-vítima
Imputação ofensiva atribuída contra a honorabilidade de alguém com a intenção de desacreditá-lo na sociedade em que vive, e provocar contra ele desprezo ou menosprezo público</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Difamacao</IRI>
        <Literal xml:lang="pt">Afeta honra e imagem social. Conecta com dano moral. Divulgação de informação ofensiva à reputação.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Difamacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que diminue a reputação ou a boa reputação do destinatário-vítima
Imputação ofensiva atribuída contra a honorabilidade de alguém com a intenção de desacreditá-lo na sociedade em que vive, e provocar contra ele desprezo ou menosprezo público

[Complemento da planilha] Afeta honra e imagem social. Conecta com dano moral. Divulgação de informação ofensiva à reputação.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Dificuldade_de_respiracao</IRI>
        <Literal xml:lang="pt">Alteracao fisiologica relacionada a estados de estresse intenso.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Dificuldade_de_respiracao</IRI>
        <Literal xml:lang="pt">Subclasse de Dano_fisico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Dificuldade_de_respiracao</IRI>
        <Literal xml:lang="pt">Dificuldade de respiracao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Dificuldade_de_respiracao</IRI>
        <Literal xml:lang="pt">Alteração fisiológica relacionada a estados de estresse intenso. Pode ocorrer em situações de intimidação ou ameaça persistente. Subclasse de Dano_fisico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Dificuldade_de_respiracao</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Alteração fisiológica relacionada a estados de estresse intenso. Pode ocorrer em situações de intimidação ou ameaça persistente. Subclasse de Dano_fisico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Direitos_negados</IRI>
        <Literal xml:lang="pt">Argumentacao para retirada de direitos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Direitos_negados</IRI>
        <Literal xml:lang="pt">Estrategia normativa.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Direitos_negados</IRI>
        <Literal xml:lang="pt">Direitos negados</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Direitos_negados</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que disputa ou nega direitos civis ou políticos ao destinatário-vítima, incluindo os direitos de representação política, atividade política, direito de manifestação ou direito de comparecer ou falar em público
Usa do fundamento de que o destinatário-vítima é uma minoria.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Direitos_negados</IRI>
        <Literal xml:lang="pt">Legitima exclusão jurídica. Estratégia normativa. Argumentação para retirada de direitos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Direitos_negados</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que disputa ou nega direitos civis ou políticos ao destinatário-vítima, incluindo os direitos de representação política, atividade política, direito de manifestação ou direito de comparecer ou falar em público
Usa do fundamento de que o destinatário-vítima é uma minoria. Também advoga chamada para uma ação que tem como objetivo impedir o acesso aos direitos do destinatário-vítima

[Complemento da planilha] Legitima exclusão jurídica. Estratégia normativa. Argumentação para retirada de direitos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_LGBTQIfobico</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal (via Natureza_afetiva).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_LGBTQIfobico</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado a pessoas LGBTQIA+.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_LGBTQIfobico</IRI>
        <Literal xml:lang="pt">Discurso LGBTQIfobico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_LGBTQIfobico</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza afetiva, direcionado a comunidade LGBTQIA+</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_LGBTQIfobico</IRI>
        <Literal xml:lang="pt">Mobiliza hostilidade baseada em orientação sexual e/ou identidade de gênero. Classe específica sob Natureza_principal (via Natureza_afetiva). Discurso de ódio direcionado a pessoas LGBTQIA+.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_LGBTQIfobico</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza afetiva, direcionado a comunidade LGBTQIA+

[Complemento da planilha] Mobiliza hostilidade baseada em orientação sexual e/ou identidade de gênero. Classe específica sob Natureza_principal (via Natureza_afetiva). Discurso de ódio direcionado a pessoas LGBTQIA+.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_antissemita</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal; pode participar de interseccionalidade.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_antissemita</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado contra pessoas judias.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_antissemita</IRI>
        <Literal xml:lang="pt">Discurso antissemita</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_antissemita</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza disposita e afiliativa, direcionado a semitas, especialmente judeus e árabes, e que nega o holocausto</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_antissemita</IRI>
        <Literal xml:lang="pt">Mobiliza preconceitos e estereótipos antissemitas, podendo articular dimensão religiosa e étnica. Classe específica sob Natureza_principal; pode participar de interseccionalidade. Discurso de ódio direcionado contra pessoas judias.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_antissemita</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza disposita e afiliativa, direcionado a semitas, especialmente judeus e árabes, e que nega o holocausto

[Complemento da planilha] Mobiliza preconceitos e estereótipos antissemitas, podendo articular dimensão religiosa e étnica. Classe específica sob Natureza_principal; pode participar de interseccionalidade. Discurso de ódio direcionado contra pessoas judias.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_aporofobico</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_aporofobico</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado a pessoas em situacao de pobreza ou vulnerabilidade economica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_aporofobico</IRI>
        <Literal xml:lang="pt">Discurso aporofobico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_aporofobico</IRI>
        <Literal xml:lang="pt">Discurso de ódio por conduta, direcionado às pessoas pobres, desamparadas e/ou que não apresentam o aspecto de quem tem algum poder aquisitivo ou posição social relevante no sistema capitalista, atribuindo-lhes à culpa absoluta por sua condição.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_aporofobico</IRI>
        <Literal xml:lang="pt">Baseia-se na rejeição a condições socioeconômicas. Classe específica sob Natureza_principal. Discurso de ódio direcionado a pessoas em situação de pobreza ou vulnerabilidade econômica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_aporofobico</IRI>
        <Literal xml:lang="pt">Discurso de ódio por conduta, direcionado às pessoas pobres, desamparadas e/ou que não apresentam o aspecto de quem tem algum poder aquisitivo ou posição social relevante no sistema capitalista, atribuindo-lhes à culpa absoluta por sua condição.

[Complemento da planilha] Baseia-se na rejeição a condições socioeconômicas. Classe específica sob Natureza_principal. Discurso de ódio direcionado a pessoas em situação de pobreza ou vulnerabilidade econômica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_capacitista</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_capacitista</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado contra pessoas com deficiencia.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_capacitista</IRI>
        <Literal xml:lang="pt">Discurso capacitista</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_capacitista</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos, direcionado às pessoas com deficiência de natureza física, mental, intelectual ou sensorial, considerando que a deficiência as define como menos capazes</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_capacitista</IRI>
        <Literal xml:lang="pt">Mobiliza desvalorização e estigmatização de capacidades físicas ou cognitivas. Classe específica sob Natureza_principal. Discurso de ódio direcionado contra pessoas com deficiência.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_capacitista</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos, direcionado às pessoas com deficiência de natureza física, mental, intelectual ou sensorial, considerando que a deficiência as define como menos capazes

[Complemento da planilha] Mobiliza desvalorização e estigmatização de capacidades físicas ou cognitivas. Classe específica sob Natureza_principal. Discurso de ódio direcionado contra pessoas com deficiência.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">Classe central da ontologia.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">Evento comunicacional de expressao/circulacao de odio.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">Fenomeno comunicativo manifestado em Plataformas Digitais.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">Discurso de odio</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">Discurso de odio online</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">Conjunto de circunstâncias socioculturais e situacionais nas quais o discurso de ódio é produzido e circula. Influencia interpretação, alcance e impacto da manifestação odienta. Classe estruturante da subontologia.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_de_odio</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Conjunto de circunstâncias socioculturais e situacionais nas quais o discurso de ódio é produzido e circula. Influencia interpretação, alcance e impacto da manifestação odienta. Classe estruturante da subontologia.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_de_odio_por_aparencia</IRI>
        <Literal xml:lang="pt">Discurso de odio baseado na aparencia corporal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_de_odio_por_aparencia</IRI>
        <Literal xml:lang="pt">No arranjo V2, fica sob Natureza_por_atributos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_de_odio_por_aparencia</IRI>
        <Literal xml:lang="pt">Discurso de odio por aparencia</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_de_odio_por_aparencia</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos, direcionado às pessoas por conta de sua aparência física, em especial flacidez, excesso de gordura e/ou que estão fora do padrão de beleza tido como ideal pelo agente odiador ou grupo ao qual pertence ou se identifica
Geralmente associa beleza, saúde e potência.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_de_odio_por_aparencia</IRI>
        <Literal xml:lang="pt">Inclui ataques associados à gordofobia e discriminação estética. No arranjo V2, fica sob Natureza_por_atributos. Discurso de ódio baseado na aparência corporal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_de_odio_por_aparencia</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos, direcionado às pessoas por conta de sua aparência física, em especial flacidez, excesso de gordura e/ou que estão fora do padrão de beleza tido como ideal pelo agente odiador ou grupo ao qual pertence ou se identifica
Geralmente associa beleza, saúde e potência.

[Complemento da planilha] Inclui ataques associados à gordofobia e discriminação estética. No arranjo V2, fica sob Natureza_por_atributos. Discurso de ódio baseado na aparência corporal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_etarista</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado contra pessoas com base na idade.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_etarista</IRI>
        <Literal xml:lang="pt">No arranjo V2, fica sob Natureza_por_atributos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_etarista</IRI>
        <Literal xml:lang="pt">Discurso etarista</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_etarista</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos e por conduta direcionado às pessoas idosas, refletindo uma resistência frequente ao curso natural do envelhecimento
O discurso de ódio etário associa as pessoas de mais idade a seres mais frágeis e improdutivos, atribuindo-lhes à culpa absoluta por sua condição.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_etarista</IRI>
        <Literal xml:lang="pt">Mobiliza estigmas e inferiorização associados ao envelhecimento ou faixa etária. No arranjo V2, fica sob Natureza_por_atributos. Discurso de ódio direcionado contra pessoas com base na idade.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_etarista</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos e por conduta direcionado às pessoas idosas, refletindo uma resistência frequente ao curso natural do envelhecimento
O discurso de ódio etário associa as pessoas de mais idade a seres mais frágeis e improdutivos, atribuindo-lhes à culpa absoluta por sua condição.

[Complemento da planilha] Mobiliza estigmas e inferiorização associados ao envelhecimento ou faixa etária. No arranjo V2, fica sob Natureza_por_atributos. Discurso de ódio direcionado contra pessoas com base na idade.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_intolerante_religioso</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_intolerante_religioso</IRI>
        <Literal xml:lang="pt">Discurso de odio baseado em intolerancia religiosa.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_intolerante_religioso</IRI>
        <Literal xml:lang="pt">Discurso intolerante religioso</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_intolerante_religioso</IRI>
        <Literal xml:lang="pt">Discurso de ódio baseado em intolerância religiosa. Ataca indivíduos ou grupos com base em crenças, práticas ou pertença religiosa. Classe específica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_intolerante_religioso</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Discurso de ódio baseado em intolerância religiosa. Ataca indivíduos ou grupos com base em crenças, práticas ou pertença religiosa. Classe específica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_misogino</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_misogino</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado contra mulheres.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_misogino</IRI>
        <Literal xml:lang="pt">Discurso misogino</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_misogino</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos, direcionado às mulheres, e, por extensão, a tudo que está associado com os estereótipos tradicionalmente femininos, considerando como de menor prestígio social.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_misogino</IRI>
        <Literal xml:lang="pt">Mobiliza inferiorização e hostilidade baseada em gênero. Classe específica sob Natureza_principal. Discurso de ódio direcionado contra mulheres.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_misogino</IRI>
        <Literal xml:lang="pt">Discurso de ódio por atributos, direcionado às mulheres, e, por extensão, a tudo que está associado com os estereótipos tradicionalmente femininos, considerando como de menor prestígio social.

[Complemento da planilha] Mobiliza inferiorização e hostilidade baseada em gênero. Classe específica sob Natureza_principal. Discurso de ódio direcionado contra mulheres.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_politico_partidario</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_politico_partidario</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado a adversarios politicos ou partidarios.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_politico_partidario</IRI>
        <Literal xml:lang="pt">Discurso politico partidario</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_politico_partidario</IRI>
        <Literal xml:lang="pt">Discurso de ódio direcionado a adversários políticos ou partidários. Mobiliza hostilidade baseada em alinhamento político percebido. Classe específica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_politico_partidario</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Discurso de ódio direcionado a adversários políticos ou partidários. Mobiliza hostilidade baseada em alinhamento político percebido. Classe específica sob Natureza_principal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_racialista</IRI>
        <Literal xml:lang="pt">Discurso de odio baseado em hierarquizacao racial.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_racialista</IRI>
        <Literal xml:lang="pt">No arranjo V2, fica sob Natureza_por_atributos; interseccionalidade via combinacao.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_racialista</IRI>
        <Literal xml:lang="pt">Discurso racialista</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_racialista</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza afiliativa e por atributos, direcionado às pessoas por sua raça, etnia e/ou cor da pele, especialmente membros de grupos racialmente identificados como negros e indígenas
É manifestado de várias formas, principalmente pelo juízo baseado em estereótipos acerca de indivíduos e pela atribuição de tratamento diferenciado, inferior, ultrajante, sustentado pela produção social, cultural e política da identidade racial/étnica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_racialista</IRI>
        <Literal xml:lang="pt">Mobiliza inferiorização e estereótipos associados a raça/etnia. No arranjo V2, fica sob Natureza_por_atributos; interseccionalidade via combinação. Discurso de ódio baseado em hierarquização racial.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_racialista</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza afiliativa e por atributos, direcionado às pessoas por sua raça, etnia e/ou cor da pele, especialmente membros de grupos racialmente identificados como negros e indígenas
É manifestado de várias formas, principalmente pelo juízo baseado em estereótipos acerca de indivíduos e pela atribuição de tratamento diferenciado, inferior, ultrajante, sustentado pela produção social, cultural e política da identidade racial/étnica.

[Complemento da planilha] Mobiliza inferiorização e estereótipos associados a raça/etnia. No arranjo V2, fica sob Natureza_por_atributos; interseccionalidade via combinação. Discurso de ódio baseado em hierarquização racial.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_xenofobico</IRI>
        <Literal xml:lang="pt">Classe especifica sob Natureza_principal (via Natureza_afiliativa).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Discurso_xenofobico</IRI>
        <Literal xml:lang="pt">Discurso de odio direcionado contra estrangeiros, migrantes ou grupos percebidos como “de fora”.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Discurso_xenofobico</IRI>
        <Literal xml:lang="pt">Discurso xenofobico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Discurso_xenofobico</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza afiliativa, direcionado àquele que não é natural do lugar do agente odiador, incluindo imigrantes e migrantes</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Discurso_xenofobico</IRI>
        <Literal xml:lang="pt">Baseia-se na rejeição a origem nacional, cultural ou comunitária. Classe específica sob Natureza_principal (via Natureza_afiliativa). Discurso de ódio direcionado contra estrangeiros, migrantes ou grupos percebidos como “de fora”.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Discurso_xenofobico</IRI>
        <Literal xml:lang="pt">Discurso de ódio de natureza afiliativa, direcionado àquele que não é natural do lugar do agente odiador, incluindo imigrantes e migrantes

[Complemento da planilha] Baseia-se na rejeição a origem nacional, cultural ou comunitária. Classe específica sob Natureza_principal (via Natureza_afiliativa). Discurso de ódio direcionado contra estrangeiros, migrantes ou grupos percebidos como “de fora”.</Literal>
    </AnnotationAssertion>
