    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Diversao</IRI>
        <Literal xml:lang="pt">Modo mental associado a busca de entretenimento na manifestacao do discurso de odio.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Diversao</IRI>
        <Literal xml:lang="pt">Diversao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Emoji_como_recurso_odiento</IRI>
        <Literal xml:lang="pt">Estrategia semantica digital.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Emoji_como_recurso_odiento</IRI>
        <Literal xml:lang="pt">Uso codificado de emojis para sinalizar hostilidade.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Emoji_como_recurso_odiento</IRI>
        <Literal xml:lang="pt">Emoji como recurso odiento</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Emoji_como_recurso_odiento</IRI>
        <Literal xml:lang="pt">Uso codificado de emojis para sinalizar hostilidade. Pode funcionar como código de grupo ou evasão de moderação. Estratégia semântica digital.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Emoji_como_recurso_odiento</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Uso codificado de emojis para sinalizar hostilidade. Pode funcionar como código de grupo ou evasão de moderação. Estratégia semântica digital.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Estereotipo_negativo</IRI>
        <Literal xml:lang="pt">Elemento recorrente na tese.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Estereotipo_negativo</IRI>
        <Literal xml:lang="pt">Generalizacao depreciativa aplicada a grupo social.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Estereotipo_negativo</IRI>
        <Literal xml:lang="pt">Estereotipo negativo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Estereotipo_negativo</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que defende que todos os membros do grupo do destinatário-vítima tem certas características/comportamentos negativos, ou desprezíveis, ou antissociais que justificam a sua discriminação e invalidam os seus pedidos de certos direitos ou de igualdade de tratamento</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Estereotipo_negativo</IRI>
        <Literal xml:lang="pt">Sustenta preconceito estrutural. Elemento recorrente na tese. Generalização depreciativa aplicada a grupo social.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Estereotipo_negativo</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que defende que todos os membros do grupo do destinatário-vítima tem certas características/comportamentos negativos, ou desprezíveis, ou antissociais que justificam a sua discriminação e invalidam os seus pedidos de certos direitos ou de igualdade de tratamento

[Complemento da planilha] Sustenta preconceito estrutural. Elemento recorrente na tese. Generalização depreciativa aplicada a grupo social.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Estrangeiro</IRI>
        <Literal xml:lang="pt">Pessoa de nacionalidade distinta do pais de referencia.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Estrangeiro</IRI>
        <Literal xml:lang="pt">Subclasse individual.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Estrangeiro</IRI>
        <Literal xml:lang="pt">Estrangeiro</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Estrangeiro</IRI>
        <Literal xml:lang="pt">Pode ser alvo de xenofobia. Subclasse individual. Pessoa de nacionalidade distinta do país de referência.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Estrangeiro</IRI>
        <Literal xml:lang="pt">Pessoa que não é natural do lugar do agente odiador
O estrangeiro pode ser imigrantes, migrantes ou refugiados

[Complemento da planilha] Pode ser alvo de xenofobia. Subclasse individual. Pessoa de nacionalidade distinta do país de referência.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
