    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Plataforma_digital</IRI>
        <Literal xml:lang="pt">Ambiente sociotécnico onde o discurso de ódio é produzido, circula e é moderado. Integra infraestrutura técnica, regras privadas, sistemas algorítmicos e práticas de governança. Conceito robusto derivado da tese.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Plataforma_digital</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Ambiente sociotécnico onde o discurso de ódio é produzido, circula e é moderado. Integra infraestrutura técnica, regras privadas, sistemas algorítmicos e práticas de governança. Conceito robusto derivado da tese.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
