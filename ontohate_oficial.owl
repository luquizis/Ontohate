    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Hater_oportunista</IRI>
        <Literal xml:lang="pt">Papel atribuído ao agente odiador humano ou dispositivo odiador que aproveitando de incidentes particulares ou eventos gatilhos, como um ataque terrorista, manifesta discurso de ódio ao destinatário-vítima</Literal>
