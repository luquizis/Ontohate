    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Idoso</IRI>
        <Literal xml:lang="pt">Pode ser alvo de etarismo. Subclasse individual. Pessoa em faixa etária avançada.</Literal>
    </AnnotationAssertion>
