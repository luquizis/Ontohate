    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Natureza_dispositiva</IRI>
        <Literal xml:lang="pt">Natureza baseada em disposições, crenças e convicções ideológicas. Direciona hostilidade a posições religiosas ou político-partidárias atribuídas ao destinatário-vítima. Reinterpretação V2 da categoria V1 “dispositiva”.</Literal>
    </AnnotationAssertion>
