    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Natureza_por_atributos</IRI>
        <Literal xml:lang="pt">Natureza baseada em atributos físicos, biológicos, corporais ou marcadores sociais atribuídos ao corpo. Direciona o ataque a características corporais ou marcadores como raça/idade/aparência. Reinterpretação V2 da categoria V1 “por atributos”.</Literal>
    </AnnotationAssertion>
