        <Literal xml:lang="pt">Classe intermediaria estrutural.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Estrategias_Discursivas</IRI>
        <Literal xml:lang="pt">Recursos retoricos utilizados para estruturar e legitimar o ataque odiento.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Estrategias_Discursivas</IRI>
        <Literal xml:lang="pt">Estrategias Discursivas</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Estrategias_Discursivas</IRI>
        <Literal xml:lang="pt">Recursos retóricos utilizados para estruturar e legitimar o ataque odiento. Operam no nível argumentativo e simbólico. Classe intermediária estrutural.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Estrategias_Discursivas</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Recursos retóricos utilizados para estruturar e legitimar o ataque odiento. Operam no nível argumentativo e simbólico. Classe intermediária estrutural.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
