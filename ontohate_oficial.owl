    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Adversario_politico</IRI>
        <Literal xml:lang="pt">Pessoa identificada por posicionamento politico divergente.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Adversario_politico</IRI>
        <Literal xml:lang="pt">Subclasse individual.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Adversario_politico</IRI>
        <Literal xml:lang="pt">Adversario politico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Adversario_politico</IRI>
        <Literal xml:lang="pt">Pode ser alvo de discurso político-partidário de ódio. Subclasse individual. Pessoa identificada por posicionamento político divergente.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Adversario_politico</IRI>
        <Literal xml:lang="pt">Pessoa que atua na esfera política por meio de eleição, nomeação ou designação, de forma voluntária ou remunerada, e que se coloca numa posição política contrária a do agente odiador
pessoa que manifesta opinião contrária a do agente odiador em relação a pleitos eleitorais, políticas públicas ou que comunga de espectro político divergente

[Complemento da planilha] Pode ser alvo de discurso político-partidário de ódio. Subclasse individual. Pessoa identificada por posicionamento político divergente.</Literal>
    </AnnotationAssertion>
