        <IRI>#Indicador_de_risco_odiento</IRI>
        <Literal xml:lang="pt">Métrica ou sinal utilizado para estimar probabilidade de conteúdo odiento. Pode derivar de denúncias, padrões linguísticos ou modelos preditivos. Fundamental para moderação algorítmica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Indicador_de_risco_odiento</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Métrica ou sinal utilizado para estimar probabilidade de conteúdo odiento. Pode derivar de denúncias, padrões linguísticos ou modelos preditivos. Fundamental para moderação algorítmica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
