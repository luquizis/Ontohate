        <Literal xml:lang="pt">Pode ser alvo de racismo. Subclasse individual. Pessoa identificada racialmente como negra.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Negro</IRI>
        <Literal xml:lang="pt">Pessoa que se autodeclara preto ou pardo ou definição análoga.

[Complemento da planilha] Pode ser alvo de racismo. Subclasse individual. Pessoa identificada racialmente como negra.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
