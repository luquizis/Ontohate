    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Refugiado</IRI>
        <Literal xml:lang="pt">Pessoa que busca protecao internacional por perseguicao.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Refugiado</IRI>
        <Literal xml:lang="pt">Subclasse individual.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Refugiado</IRI>
        <Literal xml:lang="pt">Refugiado</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Refugiado</IRI>
        <Literal xml:lang="pt">Pode ser alvo de hostilidade xenófoba. Subclasse individual. Pessoa que busca proteção internacional por perseguição.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Refugiado</IRI>
        <Literal xml:lang="pt">Pessoa que se encontram fora do seu próprio território nacional, devido ao temor de perseguição e risco de violência, isto é, pessoas que foram forçadas a deixarem seu país de origem, e requerem “proteção internacional”.
O termo tem suas raízes em instrumentos legais internacionais, notadamente a Convenção sobre o Estatuto dos Refugiados, de 1951, o Protocolo de 1967 e a Convenção de 1969 da Organização da Unidade Africana (OUA).

[Complemento da planilha] Pode ser alvo de hostilidade xenófoba. Subclasse individual. Pessoa que busca proteção internacional por perseguição.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Regra_comunitaria</IRI>
        <Literal xml:lang="pt">Derivacao operacional da politica de uso.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Regra_comunitaria</IRI>
        <Literal xml:lang="pt">Norma especifica aplicada a comunidade da plataforma.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Regra_comunitaria</IRI>
        <Literal xml:lang="pt">Regra comunitaria</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Regra_comunitaria</IRI>
        <Literal xml:lang="pt">Norma específica aplicada à comunidade da plataforma. Pode incluir diretrizes sobre discurso de ódio e assédio. Derivação operacional da política de uso.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Regra_comunitaria</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Norma específica aplicada à comunidade da plataforma. Pode incluir diretrizes sobre discurso de ódio e assédio. Derivação operacional da política de uso.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Restricoes_a_capacidade_de_se_identificar_como_membro_do_grupo</IRI>
        <Literal xml:lang="pt">Limitacao na autoidentificacao coletiva da vitima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Restricoes_a_capacidade_de_se_identificar_como_membro_do_grupo</IRI>
        <Literal xml:lang="pt">Subclasse especifica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Restricoes_a_capacidade_de_se_identificar_como_membro_do_grupo</IRI>
        <Literal xml:lang="pt">Restricoes a capacidade de se identificar como membro do grupo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Restricoes_a_capacidade_de_se_identificar_como_membro_do_grupo</IRI>
        <Literal xml:lang="pt">Limitação na autoidentificação coletiva da vítima. Pode afetar pertencimento e identidade social. Subclasse específica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Restricoes_a_capacidade_de_se_identificar_como_membro_do_grupo</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Limitação na autoidentificação coletiva da vítima. Pode afetar pertencimento e identidade social. Subclasse específica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Retirada_de_oportunidades_expressivas</IRI>
        <Literal xml:lang="pt">Limitacao da capacidade de manifestacao publica da vitima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Retirada_de_oportunidades_expressivas</IRI>
        <Literal xml:lang="pt">Subclasse especifica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Retirada_de_oportunidades_expressivas</IRI>
        <Literal xml:lang="pt">Retirada de oportunidades expressivas</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Retirada_de_oportunidades_expressivas</IRI>
        <Literal xml:lang="pt">Pode decorrer de intimidação ou autocensura. Subclasse específica. Limitação da capacidade de manifestação pública da vítima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Retirada_de_oportunidades_expressivas</IRI>
        <Literal xml:lang="pt">É um dano social que resulta no desfavorecimento do destinatário-vítima no convívio social
Efetiva a negação da igualdade de oportunidades e direitos. Exemplo: é recusado a moradia a alguém com base em sua raça

[Complemento da planilha] Pode decorrer de intimidação ou autocensura. Subclasse específica. Limitação da capacidade de manifestação pública da vítima.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Sentimento_de_medo</IRI>
        <Literal xml:lang="pt">Experiencia emocional de temor ou inseguranca.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Sentimento_de_medo</IRI>
        <Literal xml:lang="pt">Subclasse especifica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Sentimento_de_medo</IRI>
        <Literal xml:lang="pt">Sentimento de medo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Sentimento_de_medo</IRI>
        <Literal xml:lang="pt">Pode levar à retração comunicativa ou isolamento. Subclasse específica. Experiência emocional de temor ou insegurança.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Sentimento_de_medo</IRI>
        <Literal xml:lang="pt">É um dano psicológico que desperta a aversão, receio ou pânico do destinatário-vítima em se expressar no debate público, sofrer alguma retaliação online ou na vida real

[Complemento da planilha] Pode levar à retração comunicativa ou isolamento. Subclasse específica. Experiência emocional de temor ou insegurança.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Silenciamento_no_debate_publico</IRI>
        <Literal xml:lang="pt">Exclusao da vitima da esfera publica de discussao.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Silenciamento_no_debate_publico</IRI>
        <Literal xml:lang="pt">Subclasse especifica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Silenciamento_no_debate_publico</IRI>
        <Literal xml:lang="pt">Silenciamento no debate publico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Silenciamento_no_debate_publico</IRI>
        <Literal xml:lang="pt">Contribui para invisibilização social. Subclasse específica. Exclusão da vítima da esfera pública de discussão.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Silenciamento_no_debate_publico</IRI>
        <Literal xml:lang="pt">É um dano social que subordina e silencia o destinatário-vítima, levando-o a abandonar ou ignorar a discussão e/ou o debate público
Prejudica a participação igualitária na deliberação democrática

[Complemento da planilha] Contribui para invisibilização social. Subclasse específica. Exclusão da vítima da esfera pública de discussão.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Sistema_algoritmico</IRI>
        <Literal xml:lang="pt">Conecta com Contexto_algoritmico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Sistema_algoritmico</IRI>
        <Literal xml:lang="pt">Conjunto de mecanismos automatizados que organizam visibilidade e circulacao de conteudo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Sistema_algoritmico</IRI>
        <Literal xml:lang="pt">Sistema algoritmico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Sistema_algoritmico</IRI>
        <Literal xml:lang="pt">Conjunto de mecanismos automatizados que organizam visibilidade e circulação de conteúdo. Envolve recomendação, ranqueamento, priorização e detecção automática. Conecta com Contexto_algoritmico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Sistema_algoritmico</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Conjunto de mecanismos automatizados que organizam visibilidade e circulação de conteúdo. Envolve recomendação, ranqueamento, priorização e detecção automática. Conecta com Contexto_algoritmico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Sistema_de_moderacao</IRI>
        <Literal xml:lang="pt">Classe central da moderacao.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Sistema_de_moderacao</IRI>
        <Literal xml:lang="pt">Conjunto de mecanismos responsaveis por avaliar e intervir sobre conteudos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Sistema_de_moderacao</IRI>
        <Literal xml:lang="pt">Sistema de moderacao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Sistema_de_moderacao</IRI>
        <Literal xml:lang="pt">Conjunto de mecanismos responsáveis por avaliar e intervir sobre conteúdos. Pode operar de forma humana, automatizada ou híbrida. Classe central da moderação.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Sistema_de_moderacao</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Conjunto de mecanismos responsáveis por avaliar e intervir sobre conteúdos. Pode operar de forma humana, automatizada ou híbrida. Classe central da moderação.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Subumanizacao</IRI>
        <Literal xml:lang="pt">Estrategia extrema.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Subumanizacao</IRI>
        <Literal xml:lang="pt">Representacao da vitima como menos que humana.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Subumanizacao</IRI>
        <Literal xml:lang="pt">Subumanizacao</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Subumanizacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que faz co-relação ou usa de comparação entre o destinatário-vítima e pragas ou sub-humano</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Subumanizacao</IRI>
        <Literal xml:lang="pt">Facilita legitimação da violência. Estratégia extrema. Representação da vítima como menos que humana.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Subumanizacao</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que faz co-relação ou usa de comparação entre o destinatário-vítima e pragas ou sub-humano

[Complemento da planilha] Facilita legitimação da violência. Estratégia extrema. Representação da vítima como menos que humana.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Supremacia_branca</IRI>
        <Literal xml:lang="pt">Estrategia ideologica estruturante.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Supremacia_branca</IRI>
        <Literal xml:lang="pt">Ideologia de hierarquizacao racial utilizada como fundamento do ataque.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Supremacia_branca</IRI>
        <Literal xml:lang="pt">Supremacia branca</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Supremacia_branca</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que advoga a falsa ideia da superioridade natural do homem branco</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Supremacia_branca</IRI>
        <Literal xml:lang="pt">Afirma superioridade racial normativa. Estratégia ideológica estruturante. Ideologia de hierarquização racial utilizada como fundamento do ataque.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Supremacia_branca</IRI>
        <Literal xml:lang="pt">Gênero discursivo odiento que advoga a falsa ideia da superioridade natural do homem branco

[Complemento da planilha] Afirma superioridade racial normativa. Estratégia ideológica estruturante. Ideologia de hierarquização racial utilizada como fundamento do ataque.</Literal>
    </AnnotationAssertion>
