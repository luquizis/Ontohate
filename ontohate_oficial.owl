        <Literal xml:lang="pt">Sistema tecnico utilizado para disseminar discurso de odio.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Dispositivo_odiador</IRI>
        <Literal xml:lang="pt">Dispositivo odiador</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Dispositivo_odiador</IRI>
        <Literal xml:lang="pt">Sistema técnico utilizado para disseminar discurso de ódio. Inclui mecanismos automatizados de amplificação. Agente não humano.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Dispositivo_odiador</IRI>
        <Literal xml:lang="pt">[Fonte: planilha] Sistema técnico utilizado para disseminar discurso de ódio. Inclui mecanismos automatizados de amplificação. Agente não humano.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Dissidente_religioso</IRI>
        <Literal xml:lang="pt">Pessoa que diverge de determinada tradicao religiosa dominante.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Dissidente_religioso</IRI>
        <Literal xml:lang="pt">Subclasse individual.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Dissidente_religioso</IRI>
        <Literal xml:lang="pt">Dissidente religioso</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Dissidente_religioso</IRI>
        <Literal xml:lang="pt">Pode sofrer intolerância religiosa. Subclasse individual. Pessoa que diverge de determinada tradição religiosa dominante.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Dissidente_religioso</IRI>
        <Literal xml:lang="pt">Pessoa que discorda e/ou recusa os preceitos de uma religião

[Complemento da planilha] Pode sofrer intolerância religiosa. Subclasse individual. Pessoa que diverge de determinada tradição religiosa dominante.</Literal>
    </AnnotationAssertion>
