        <Literal xml:lang="pt">Imagem de odio</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Imagem_de_odio</IRI>
        <Literal xml:lang="pt">Recurso que inclui fotografias, ilustrações, emojis, emoticons, kaoemojis, bitmap, vetores, gráficos, tabelas ou infográficos com manifestação explícita ou velada de discurso de ódio</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Imagem_de_odio</IRI>
        <Literal xml:lang="pt">Pode reforçar estereótipos e desumanização. Forma visual. Conteúdo visual utilizado para inferiorização ou ataque simbólico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
        <IRI>#Imagem_de_odio</IRI>
        <Literal xml:lang="pt">Recurso que inclui fotografias, ilustrações, emojis, emoticons, kaoemojis, bitmap, vetores, gráficos, tabelas ou infográficos com manifestação explícita ou velada de discurso de ódio

[Complemento da planilha] Pode reforçar estereótipos e desumanização. Forma visual. Conteúdo visual utilizado para inferiorização ou ataque simbólico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Imigrante</IRI>
        <Literal xml:lang="pt">Pessoa que migrou para outro pais.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Imigrante</IRI>
        <Literal xml:lang="pt">Subclasse individual.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
