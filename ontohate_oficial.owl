        <IRI>#Politica_de_uso</IRI>
        <Literal xml:lang="pt">Conjunto de normas formais que regulam comportamento e conteúdo na plataforma. Define limites, permissões e critérios de moderação. Dimensão normativa.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
