        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Contexto_de_normas_culturais</IRI>
        <Literal xml:lang="pt">Fundamentacao sociocultural da tese.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Contexto_de_normas_culturais</IRI>
        <Literal xml:lang="pt">Contexto de normas culturais</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:associacaoDiscursoOdioV1"/>
        <IRI>#Contexto_de_normas_culturais</IRI>
        <Literal xml:lang="pt">Circunstâncias em que o discurso é manifestado em perfis, páginas ou ambientes digitais em que é vigente as normas sociológicas, econômicas e históricas (como uma página de veículo ou profissionais da imprensa, organizações da sociedade civil)
eventos ou episódios em que problemas sociais, especialmente os que envolvem direitos humanos, são expostos e discutidos</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:complementoPlanilhaV1"/>
        <IRI>#Contexto_de_normas_culturais</IRI>
        <Literal xml:lang="pt">Pode reforçar ou legitimar práticas discriminatórias. Fundamentação sociocultural da tese. Contexto baseado em valores, costumes e normas sociais compartilhadas.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="ontohatev1:conceitoFonteV1"/>
