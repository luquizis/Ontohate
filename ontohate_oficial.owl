        <IRI>#Recursos</IRI>
        <Literal xml:lang="pt">Recursos relacionados à forma material da manifestação. Correspondem ao suporte midiático do discurso. Classe intermediária estrutural.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
