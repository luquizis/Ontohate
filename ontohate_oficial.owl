        <Literal xml:lang="pt">Dimensao que indica combinacao de multiplas naturezas no mesmo ataque.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Natureza_interseccional</IRI>
        <Literal xml:lang="pt">Mudanca V2: nao substitui a natureza principal; e dimensao combinatoria.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Natureza_interseccional</IRI>
